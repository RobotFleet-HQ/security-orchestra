# Root .dockerignore — applies when building from security-orchestra/ context
# (covers both orchestrator and billing-api Docker builds)

# Dependencies
**/node_modules

# Build output (rebuilt inside Docker)
**/dist

# Environment files — never bake secrets into images
**/.env
**/.env.*
!**/.env.example

# SQLite databases — provided via volume mounts in production
**/*.db

# Test artifacts
**/coverage
**/*.test.js
**/*.spec.js

# Dev tooling
**/.eslintrc*
**/.prettierrc*
**/jest.config.*

# Source control
.git
.gitignore

# OS noise
.DS_Store
Thumbs.db
