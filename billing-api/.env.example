# ─── Billing API environment variables ────────────────────────────────────────
# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.

# ── Server ─────────────────────────────────────────────────────────────────────
# Port the HTTP server listens on.
PORT=3001

# Public base URL used to build Stripe redirect URLs (success/cancel pages).
# In production set this to your real domain, e.g. https://api.yourapp.com
BASE_URL=http://localhost:3001

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Secret API key from https://dashboard.stripe.com/apikeys
# Use sk_test_... for development, sk_live_... for production.
# Required for POST /checkout and all Stripe webhook handling.
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret from https://dashboard.stripe.com/webhooks
# Obtained after creating a webhook endpoint (or via the Stripe CLI listener).
# Required to verify that incoming webhook events are genuinely from Stripe.
# Get a local test secret with: stripe listen --print-secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email — Primary: Gmail SMTP ───────────────────────────────────────────────
# Gmail SMTP sends via Google's servers, so outgoing mail is signed with Google's
# own DKIM (d=gmail.com) and passes SPF. DMARC alignment succeeds — this is the
# highest deliverability option available with a free Gmail account.
#
# Setup:
#   1. Enable 2-Step Verification on the sending Gmail account.
#   2. Visit myaccount.google.com/apppasswords → generate an App Password.
#   3. Set GMAIL_APP_PASSWORD below. Daily limit: 500 emails.
#
# When GMAIL_APP_PASSWORD is set, all email uses Gmail SMTP.
# When unset, the system falls back to SendGrid (lower deliverability).

GMAIL_USER=contact.securityorchestra@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password-here

# ── Email — Fallback: SendGrid ────────────────────────────────────────────────
# Used only when GMAIL_APP_PASSWORD is not set. SendGrid cannot achieve DMARC
# alignment for a gmail.com FROM address (shared IP signs with sendgrid.net DKIM).
# Keep this set so the fallback path works if Gmail SMTP is unavailable.
SENDGRID_API_KEY=SG....

# FROM address sent in email headers. Defaults to GMAIL_USER when unset.
SENDGRID_FROM_EMAIL=contact.securityorchestra@gmail.com

# ── Admin / Key Provisioning ──────────────────────────────────────────────────
# URL of the orchestrator service (used to provision API keys after signup)
ORCHESTRATOR_URL=https://security-orchestra-orchestrator.onrender.com

# Shared secret for orchestrator admin endpoints (must match ORCHESTRATOR_ADMIN_KEY in orchestrator)
ORCHESTRATOR_ADMIN_KEY=your_admin_secret_here

# Secret for billing admin endpoints: DELETE /admin/user, GET /admin/failed-deliveries.
# Send as x-admin-key header or ?secret= query param.
BILLING_ADMIN_SECRET=your_billing_admin_secret_here

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Basic auth password for /dashboard — leave unset to disable dashboard
ADMIN_PASSWORD=your_secure_dashboard_password

# ── Signup rate limiting ──────────────────────────────────────────────────────
# Maximum signups allowed from a single IP per hour.
# Default: 10. Raise for shared office/corporate proxy environments. Whitelisted IPs bypass this.
SIGNUP_RATE_LIMIT_PER_IP=10

# ── Databases ──────────────────────────────────────────────────────────────────
# Path to the billing SQLite database (users, subscriptions, credits).
# Default (when unset): billing.db in the project root.
BILLING_DB_PATH=./billing.db

# Path to the shared audit log database written by the orchestrator.
# Must match AUDIT_DB_PATH in orchestrator/.env so both services use the same file.
# Default (when unset): ../../../audit.db  →  security-orchestra/audit.db
AUDIT_DB_PATH=../audit.db
