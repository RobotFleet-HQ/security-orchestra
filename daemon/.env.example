# ─── Required ─────────────────────────────────────────────────────────────────
ORCHESTRATOR_URL=https://security-orchestra-orchestrator.onrender.com
ORCHESTRATOR_API_KEY=your-orchestrator-api-key

# Site configs — JSON array. Each site:
# { "id": "site-1", "name": "Apex NC-1", "components": [...], "claimed_tier": "Tier III",
#   "as_built_description": "...", "scan_interval_hours": 24, "contact_email": "ops@example.com" }
DAEMON_SITES=[{"id":"site-1","name":"Example Site","components":[{"name":"Generator","type":"generator","manufacturer":"Cummins","internet_exposed":false,"handles_unauth_input":false,"has_known_cves":false,"is_passive":false}],"claimed_tier":"Tier III","as_built_description":"Single utility feed, one generator","scan_interval_hours":24,"contact_email":"ops@example.com"}]

# Webhook auth token (clients POST to /metrics with Authorization: Bearer <token>)
WEBHOOK_BEARER_TOKEN=change-me-32-char-random-secret

# ─── Email (required for daily digest) ────────────────────────────────────────
GMAIL_USER=contact.securityorchestra@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # 16-char Gmail App Password

# ─── Optional ─────────────────────────────────────────────────────────────────
PORT=3002
DAEMON_DB_PATH=./daemon.db
DIGEST_CRON=0 6 * * *           # 06:00 UTC daily
CVE_POLL_INTERVAL_MINUTES=60    # how often to poll NVD + CISA KEV
NVD_API_KEY=                    # optional — raises NVD rate limit 5→50 req/30s
