# ─── Orchestrator environment variables ───────────────────────────────────────
# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.

# ── API key authentication ─────────────────────────────────────────────────────
# The API key that Claude Desktop (or any MCP client) must present.
# Generate a new key with: npm run generate-key
# Format: sk_live_<32 hex chars>_<6 char checksum>
ORCHESTRATOR_API_KEY=sk_live_your_key_here

# ── Billing API ────────────────────────────────────────────────────────────────
# Base URL of the billing-api service. Leave unset to disable credit checks
# entirely (useful for local development without Stripe).
# When set, every workflow execution will check and deduct credits.
BILLING_API_URL=http://localhost:3001

# ── Audit database ────────────────────────────────────────────────────────────
# Path to the shared SQLite audit log database.
# Both the orchestrator (writer) and billing-api (reader) must point here.
# Relative paths are resolved from the compiled output directory (dist/).
# Default (when unset): ../../audit.db  →  security-orchestra/audit.db
AUDIT_DB_PATH=../audit.db

# ── Keys database ─────────────────────────────────────────────────────────────
# Path to the SQLite database that stores API key hashes.
# Default (when unset): keys.db in the project root.
# Only change this if you want to store the DB outside the project directory.
DATABASE_PATH=./keys.db

# ── Logging ───────────────────────────────────────────────────────────────────
# Controls how verbose server output is.
# Levels: error | warn | info | debug
# All orchestrator logs go to stderr so they don't interfere with the
# stdio MCP protocol on stdout.
LOG_LEVEL=info
